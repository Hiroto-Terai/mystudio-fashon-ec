{% doc %}
  Renders a product card in the ARCHIVES grid style: bordered image tile with
  wishlist toggle + slide-up quick add, and a details block (category / name / price).
  Used by the home page (Featured, Ranking) and collection/PLP grids.

  @param {product} product - The product to render. Products tagged
    "early-access" or with a truthy `metafields.custom.early_access` get a
    small "先行" badge in the top-left corner. When a `rank` badge is also
    present the two are stacked vertically so they never overlap.
  @param {number} [rank] - When present, shows a black rank badge in the
    top-left corner of the image (used by the "Weekly ranking" section).

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card', product: product, rank: forloop.index %}
{% enddoc %}
{%- liquid
  assign is_early_access = false
  assign early_access_mf = product.metafields.custom.early_access.value
  if early_access_mf or product.tags contains 'early-access'
    assign is_early_access = true
  endif
-%}
<div class="as-card" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default);">
  <div style="position:relative; overflow:hidden; aspect-ratio:3/4; background:var(--surface-subtle);">
    {%- if rank or is_early_access -%}
      <div style="position:absolute; top:0; left:0; z-index:2; display:flex; flex-direction:column; align-items:flex-start; gap:var(--space-3);">
        {%- if rank -%}
          <span style="background:var(--color-ink); color:var(--color-white); font-weight:var(--fw-black); font-size:var(--fs-lg); padding:var(--space-2) var(--space-4);">{{ rank }}</span>
        {%- endif -%}
        {%- if is_early_access -%}
          <span class="as-badge as-badge-ink" style="margin-left:var(--space-3);{% unless rank %} margin-top:var(--space-3);{% endunless %}">{{ 'products.product.badge_early_access_card' | t }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
    <a href="{{ product.url }}" style="position:absolute; inset:0; display:block;">
      {%- if product.featured_image -%}
        <img
          class="as-img"
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="800"
          height="1067"
          loading="lazy"
          style="width:100%; height:100%; object-fit:cover;"
        >
      {%- endif -%}
    </a>
    <button type="button" data-wishlist-toggle="{{ product.handle }}" data-wishlist-ns="products" class="as-wish as-iconbtn" aria-label="ウィッシュリストに追加" style="position:absolute; top:var(--space-3); right:var(--space-3); z-index:2; background:var(--color-white); border:1px solid var(--border-default); width:32px; height:32px; border-radius:999px; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--color-ink);">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8z"></path></svg>
    </button>
    {%- comment -%} Quick-add: a + button (bottom-right) opens the variant-picker modal (archives.js bindQuickAddModal). {%- endcomment -%}
    <button type="button" data-quick-add-open data-handle="{{ product.handle }}" class="as-qa-plus" aria-label="{{ 'products.product.quick_add' | t }}" style="position:absolute; right:var(--space-3); bottom:var(--space-3); z-index:2; background:var(--color-ink); color:var(--color-white); border:none; width:38px; height:38px; border-radius:999px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
    </button>
  </div>
  <a href="{{ product.url }}" style="padding:var(--space-5); display:flex; flex-direction:column; gap:var(--space-2);">
    <span style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-tertiary); font-size:10px;">{{ product.type }}</span>
    <h3 style="font-weight:var(--fw-medium); font-size:var(--fs-base);">{{ product.title }}</h3>
    <span style="font-size:var(--fs-sm); color:var(--text-secondary);">{{ product.price | money }}</span>
  </a>
</div>
