{% doc %}
  Renders a "frequently bought together" horizontal-scroll row or a
  "you may also like" grid of related products for the PDP, reusing
  snippets/product-card and excluding the product currently being viewed.

  Implementation note: uses the product's first collection (falling back to
  the automatic "All products" collection) rendered server-side, rather than
  the live Product Recommendations API. A fresh store has little purchase
  history for the recommendation engine to work from, so this keeps the row
  populated and deterministic for the 13 Shopify sample products.

  @param {product} current_product - Product to exclude from the list.
  @param {collection} source_collection - Collection to source recommendations from.
  @param {string} heading - Section heading text (already translated).
  @param {string} layout - "scroll" for the FBT row, "grid" for the 4-col related grid.
  @param {number} [max] - Maximum products to show (default 8).

  @example
  {% render 'pdp-recommendations', current_product: product, source_collection: product.collections.first, heading: 'Frequently bought together', layout: 'scroll' %}
{% enddoc %}
{%- liquid
  assign max_items = max | default: 8
  assign shown = 0
  assign source_products = source_collection.products
  assign grid_products = source_products | reverse
-%}
{%- if source_products.size > 0 -%}
  <section style="border-top:1px solid var(--border-default);">
    <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-8);">
      <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">{{ heading }}</span>
    </div>
    {%- if layout == 'scroll' -%}
      <div style="max-width:var(--page-max); margin:0 auto; padding:0 var(--page-gutter) var(--section-y); display:flex; gap:var(--space-5); overflow-x:auto; scroll-snap-type:x mandatory;">
        {%- for rec in source_products limit: 20 -%}
          {%- if rec.id == current_product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- if shown >= max_items -%}
            {%- break -%}
          {%- endif -%}
          {%- assign shown = shown | plus: 1 -%}
          <div style="flex:0 0 240px; scroll-snap-align:start;">
            {%- render 'product-card', product: rec -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="as-grid-4" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(4,1fr);">
        {%- comment -%} Reversed so "related" surfaces different items than the FBT row above when both draw from the same collection. {%- endcomment -%}
        {%- for rec in grid_products limit: 20 -%}
          {%- if rec.id == current_product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- if shown >= max_items -%}
            {%- break -%}
          {%- endif -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- render 'product-card', product: rec -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </section>
{%- endif -%}
