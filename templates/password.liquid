<section style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:var(--section-y) var(--page-gutter);">
  <div style="max-width:420px; width:100%; text-align:center; display:flex; flex-direction:column; gap:var(--space-6);">
    <span style="font-weight:var(--fw-black); font-size:var(--fs-2xl); letter-spacing:var(--tracking-widest); text-transform:uppercase;">{{ shop.name }}</span>
    <p style="font:var(--text-body); color:var(--text-secondary); line-height:var(--lh-relaxed);">{{ shop.password_message | default: 'Opening soon.' }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color:var(--color-clay); font:var(--text-body-sm);">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
      {%- endif -%}
      <div style="display:flex; align-items:center; border:1px solid var(--color-ink);">
        <input type="password" name="password" placeholder="ENTER PASSWORD" style="flex:1; border:none; outline:none; background:none; padding:var(--space-4); font:var(--text-body-sm); letter-spacing:var(--tracking-wide); text-transform:uppercase;">
        <button type="submit" style="background:var(--color-ink); color:var(--color-white); border:none; cursor:pointer; padding:0 var(--space-6); align-self:stretch; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">Enter</button>
      </div>
    {%- endform -%}
  </div>
</section>
