{%- comment -%}
  "Brand intro" two-column band: full-bleed image on one side, copy + CTA on
  the other, split by a hairline divider.
{%- endcomment -%}
<section style="border-bottom:1px solid var(--border-default);">
  <div class="as-2col" style="max-width:var(--page-max); margin:0 auto; display:grid; grid-template-columns:1fr 1fr;">
    <div class="as-card" style="overflow:hidden; min-height:460px;">
      {%- if section.settings.image -%}
        <img class="as-img" src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
      {%- else -%}
        <img class="as-img" src="{{ section.settings.fallback_image }}" alt="" width="1400" height="1750" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
      {%- endif -%}
    </div>
    <div style="padding:var(--section-y) var(--space-12); display:flex; flex-direction:column; justify-content:center; gap:var(--space-6); border-left:1px solid var(--border-default);">
      {%- if section.settings.eyebrow != blank -%}
        <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 style="font-weight:var(--fw-black); font-size:var(--fs-3xl); letter-spacing:var(--tracking-tight); text-transform:uppercase; line-height:var(--lh-tight);">{{ section.settings.heading | newline_to_br }}</h2>
      {%- if section.settings.body != blank -%}
        <p style="font:var(--text-body); color:var(--text-secondary); line-height:var(--lh-relaxed); max-width:420px;">{{ section.settings.body }}</p>
      {%- endif -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="as-fillbtn" style="align-self:flex-start; display:inline-flex; align-items:center; gap:var(--space-3); border:1px solid var(--color-ink); padding:15px var(--space-8); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink);">
        {{ section.settings.button_label }}
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand intro",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "info": "Used until a real image is picked above.", "default": "https://images.unsplash.com/photo-1618354691373-d851c5c3a990?q=80&w=1400&auto=format&fit=crop" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Studio" },
    { "type": "textarea", "id": "heading", "label": "Heading", "info": "One line per break.", "default": "Considered,\nnot seasonal" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "ARCHIVES is a Tokyo studio making garments and objects designed to be kept, repaired, and archived — never replaced. Every release is small, documented, and numbered." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "About the studio" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    {
      "name": "Brand intro",
      "settings": {
        "eyebrow": "The Studio",
        "heading": "Considered,\nnot seasonal",
        "body": "ARCHIVES is a Tokyo studio making garments and objects designed to be kept, repaired, and archived — never replaced. Every release is small, documented, and numbered.",
        "button_label": "About the studio"
      }
    }
  ]
}
{% endschema %}
