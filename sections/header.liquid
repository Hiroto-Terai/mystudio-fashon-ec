{%- liquid
  assign menu = linklists[section.settings.menu]
-%}
<header class="as-header" style="border-bottom:1px solid var(--border-default); position:sticky; top:0; z-index:40; background:rgba(255,255,255,0.9); backdrop-filter:blur(12px);">
  <div class="as-headrow" style="max-width:var(--page-max); margin:0 auto; padding:0 var(--page-gutter); height:76px; display:grid; grid-template-columns:1fr auto 1fr; align-items:center;">

    <a href="{{ routes.root_url }}" class="as-clickable as-logo" style="font-weight:var(--fw-black); font-size:var(--fs-lg); letter-spacing:var(--tracking-widest); text-transform:uppercase; justify-self:start; color:var(--color-ink);">{{ section.settings.logo_text | default: 'A R C H I V E S' }}</a>

    <nav class="as-nav-center" style="display:flex; gap:var(--space-10); justify-self:center;" aria-label="Primary">
      {%- for link in menu.links -%}
        <div class="as-navitem">
          <a href="{{ link.url }}" class="as-navlink{% if link.active or link.child_active %} is-active{% endif %}" style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink);">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <div class="as-dropdown" style="position:absolute; top:100%; left:50%; min-width:210px; background:var(--surface-page); border:1px solid var(--border-default); padding:var(--space-4); display:flex; flex-direction:column; gap:2px; box-shadow:var(--shadow-drawer);">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" class="as-clickable as-dropitem" style="font:var(--text-body-sm); color:var(--text-secondary); padding:var(--space-2); white-space:nowrap; transition:color var(--dur-base) var(--ease-standard);">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </nav>

    <div class="as-headicons" style="display:flex; gap:var(--space-5); justify-self:end; align-items:center;">
      <button data-menu-toggle class="as-iconbtn as-burger" aria-label="Menu" style="background:none; border:none; cursor:pointer; color:var(--color-ink); padding:0;">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <button data-search-toggle class="as-iconbtn" aria-label="Search" style="background:none; border:none; cursor:pointer; color:var(--color-ink); padding:0; display:flex;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      <a href="{{ routes.root_url }}pages/{{ section.settings.wishlist_handle | default: 'wishlist' }}" class="as-iconbtn" aria-label="Wishlist" style="background:none; border:none; cursor:pointer; color:var(--color-ink); padding:0; display:flex; position:relative;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8z"></path></svg>
        <span data-wishlist-badge hidden style="position:absolute; top:-7px; right:-9px; background:var(--color-ink); color:var(--color-white); font-size:9px; font-weight:var(--fw-bold); min-width:15px; height:15px; border-radius:999px; display:flex; align-items:center; justify-content:center; padding:0 3px;">0</span>
      </a>
      <button data-cart-open class="as-iconbtn" aria-label="Cart" style="background:none; border:none; cursor:pointer; color:var(--color-ink); padding:0; display:flex; position:relative;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        <span data-cart-badge{% if cart.item_count == 0 %} hidden{% endif %} style="position:absolute; top:-7px; right:-9px; background:var(--color-ink); color:var(--color-white); font-size:9px; font-weight:var(--fw-bold); min-width:15px; height:15px; border-radius:999px; display:flex; align-items:center; justify-content:center; padding:0 3px;">{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  {%- comment -%} Search panel: input + predictive-search suggest dropdown (assets/archives.js bindPredictiveSearch) {%- endcomment -%}
  <div data-search-panel hidden style="border-top:1px solid var(--border-default); background:var(--surface-page);">
    <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:var(--page-max); margin:0 auto; padding:var(--space-5) var(--page-gutter) 0; display:flex; align-items:center; gap:var(--space-4);">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-n-400)" stroke-width="1.4"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="search" name="q" data-search-input autocomplete="off" aria-label="{{ 'general.search.placeholder' | t }}" placeholder="{{ 'general.search.placeholder' | t | upcase }}" style="flex:1; border:none; outline:none; background:none; font:var(--text-body); letter-spacing:var(--tracking-wide); text-transform:uppercase; font-size:var(--fs-sm);">
      <input type="hidden" name="options[prefix]" value="last">
      <input type="hidden" name="type" value="product,article,page">
      <button type="button" data-search-toggle class="as-iconbtn" style="background:none; border:none; cursor:pointer; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary);">{{ 'general.search.close' | t }}</button>
    </form>
    <div
      data-search-suggest
      hidden
      class="as-search-suggest"
      data-loading-text="{{ 'general.search.loading' | t }}"
      data-empty-text="{{ 'general.search.no_suggestions' | t }}"
      data-collections-label="{{ 'general.search.collections' | t }}"
      data-articles-label="{{ 'general.search.articles' | t }}"
      data-pages-label="{{ 'general.search.pages' | t }}"
      style="max-width:var(--page-max); margin:0 auto; padding:0 var(--page-gutter);"
    ></div>
  </div>

  {%- comment -%} Mobile menu {%- endcomment -%}
  <div data-mobile-menu hidden class="as-mobmenu" style="border-top:1px solid var(--border-default); background:var(--surface-page);">
    <div style="padding:var(--space-2) var(--page-gutter) var(--space-6);">
      {%- for link in menu.links -%}
        <div style="border-bottom:1px solid var(--border-default); padding:var(--space-5) 0;">
          <a href="{{ link.url }}" class="as-clickable" style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-sm); color:var(--color-ink);">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <div style="display:flex; flex-wrap:wrap; gap:var(--space-3) var(--space-5); margin-top:var(--space-4);">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" class="as-clickable" style="font:var(--text-body-sm); color:var(--text-secondary);">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "A R C H I V E S"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "wishlist_handle",
      "label": "Wishlist page handle",
      "default": "wishlist"
    }
  ]
}
{% endschema %}
