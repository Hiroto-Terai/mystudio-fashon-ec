{%- comment -%}
  "@archives.studio" social strip: heading + follow link over a 6-up hairline
  grid of square images.
{%- endcomment -%}
<section style="border-bottom:1px solid var(--border-default);">
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-10); display:flex; align-items:center; justify-content:space-between; gap:var(--space-4); flex-wrap:wrap;">
    <h2 style="font-weight:var(--fw-bold); font-size:var(--fs-2xl); text-transform:uppercase; letter-spacing:var(--tracking-tight);">{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.follow_link | default: '#' }}" class="as-navlink" style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--text-secondary); white-space:nowrap;">フォローする</a>
  </div>
  <div class="as-grid-6" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(6,1fr);">
    {%- for block in section.blocks -%}
      <div class="as-card" style="aspect-ratio:1/1; overflow:hidden; border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default);" {{ block.shopify_attributes }}>
        {%- if block.settings.image -%}
          <img class="as-img" src="{{ block.settings.image | image_url: width: 500 }}" alt="" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
        {%- else -%}
          <img class="as-img" src="{{ block.settings.fallback_image }}" alt="" width="500" height="500" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Instagram",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "@archives.studio" },
    { "type": "url", "id": "follow_link", "label": "\"Follow\" link" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "info": "Used until a real image is picked above.", "default": "https://images.unsplash.com/photo-1495385794356-15371f348c31?q=80&w=500&auto=format&fit=crop" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram",
      "blocks": [
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1495385794356-15371f348c31?q=80&w=500&auto=format&fit=crop" } },
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1479064555552-3ef4979f8908?q=80&w=500&auto=format&fit=crop" } },
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?q=80&w=500&auto=format&fit=crop" } },
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1554568218-0f1715e72254?q=80&w=500&auto=format&fit=crop" } },
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1533738363-b7f9aef128ce?q=80&w=500&auto=format&fit=crop" } },
        { "type": "image", "settings": { "fallback_image": "https://images.unsplash.com/photo-1608234807905-4466023792f5?q=80&w=500&auto=format&fit=crop" } }
      ]
    }
  ]
}
{% endschema %}
