{%- comment -%}
  /collections index: header + a hairline grid of every published collection,
  linking to each collection's PLP. Falls back to onboarding demo tiles when
  the store has no collections yet, matching sections/category-tiles.liquid.
{%- endcomment -%}
<div>
  <section style="border-bottom:1px solid var(--border-default);">
    <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-10);">
      <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ 'list_collections.eyebrow' | t }}</span>
      <h1 style="font-weight:var(--fw-black); font-size:var(--fs-4xl); letter-spacing:var(--tracking-tight); text-transform:uppercase; margin-top:var(--space-4);">{{ 'list_collections.heading' | t }}</h1>
    </div>
  </section>

  <section>
    {%- if collections.size > 0 -%}
      {%- paginate collections by 24 -%}
        <div class="as-grid-4" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(4,1fr);">
          {%- for coll in collections -%}
            <a href="{{ coll.url }}" class="as-card as-clickable" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default); position:relative; display:block; aspect-ratio:1/1; overflow:hidden; background:var(--surface-subtle);">
              {%- if coll.featured_image -%}
                <img class="as-img" src="{{ coll.featured_image | image_url: width: 800 }}" alt="{{ coll.title | escape }}" width="800" height="800" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
              {%- endif -%}
              <div style="position:absolute; inset:0; display:flex; align-items:flex-end; padding:var(--space-6); background:linear-gradient(to top, rgba(0,0,0,.42), transparent 58%);">
                <span style="color:var(--color-white); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-sm);">{{ coll.title }}</span>
              </div>
            </a>
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav class="as-pagination" role="navigation" aria-label="{{ 'collection.pagination.label' | t }}" style="max-width:var(--page-max); margin:0 auto; padding:var(--space-10) var(--page-gutter); display:flex; justify-content:center;">
            {{ paginate | default_pagination }}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      {%- comment -%} Onboarding demo tiles: shown until collections exist. {%- endcomment -%}
      <div class="as-grid-4" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(4,1fr);">
        {%- for i in (1..4) -%}
          {%- case i -%}
            {%- when 1 -%}
              {%- assign demo_image = 'https://images.unsplash.com/photo-1551028719-00167b16eac5?q=80&w=800&auto=format&fit=crop' -%}
              {%- assign demo_label = 'Outerwear' -%}
            {%- when 2 -%}
              {%- assign demo_image = 'https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=800&auto=format&fit=crop' -%}
              {%- assign demo_label = 'Denim' -%}
            {%- when 3 -%}
              {%- assign demo_image = 'https://images.unsplash.com/photo-1489987707025-afc232f7ea0f?q=80&w=800&auto=format&fit=crop' -%}
              {%- assign demo_label = 'Knitwear' -%}
            {%- when 4 -%}
              {%- assign demo_image = 'https://images.unsplash.com/photo-1516826957135-700dedea698c?q=80&w=800&auto=format&fit=crop' -%}
              {%- assign demo_label = 'Accessories' -%}
          {%- endcase -%}
          <div class="as-card" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default); position:relative; aspect-ratio:1/1; overflow:hidden; background:var(--surface-subtle);">
            <img class="as-img" src="{{ demo_image }}" alt="{{ demo_label }}" width="800" height="800" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
            <div style="position:absolute; inset:0; display:flex; align-items:flex-end; padding:var(--space-6); background:linear-gradient(to top, rgba(0,0,0,.42), transparent 58%);">
              <span style="color:var(--color-white); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-sm);">{{ demo_label }}</span>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "Main list collections",
  "settings": [],
  "presets": [
    { "name": "Main list collections" }
  ],
  "enabled_on": {
    "templates": ["list-collections"]
  }
}
{% endschema %}
