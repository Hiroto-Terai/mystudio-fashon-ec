{%- comment -%}
  Cart drawer (Sprint 4: section-rendered). Mirrors design-reference
  Archives-Storefront.html <!-- Cart Drawer --> view. The drawer shell
  (scrim + aside open/close state) lives outside [data-cart-drawer-contents]
  so it survives re-renders; everything that changes when the cart changes
  (item list, subtotal, free-shipping bar, coupon) lives inside that wrapper
  and is swapped in from the Section Rendering API response by archives.js.
{%- endcomment -%}
{%- liquid
  assign threshold = settings.free_shipping_threshold | default: 30000
  assign threshold_sub = threshold | times: 100
  assign remaining = threshold_sub | minus: cart.total_price
  assign pct = 0
  if cart.total_price > 0
    assign pct = cart.total_price | times: 100 | divided_by: threshold_sub
  endif
  if pct > 100
    assign pct = 100
  endif
-%}
<div data-cart-scrim hidden class="as-cart-scrim" style="position:fixed; inset:0; background:var(--surface-scrim); z-index:90; opacity:0; transition:opacity var(--dur-base) var(--ease-standard);"></div>

<aside data-cart-drawer hidden class="as-cart-drawer" aria-label="{{ 'general.cart.title' | t }}" style="position:fixed; top:0; right:0; height:100vh; width:min(440px, 92vw); background:var(--surface-page); z-index:95; display:flex; flex-direction:column; transform:translateX(100%); transition:transform var(--dur-drawer) var(--ease-standard); box-shadow:var(--shadow-drawer);">
  <script>window.ArchivesMoneyFormat = window.ArchivesMoneyFormat || {{ shop.money_format | json }};</script>

  <div data-cart-drawer-contents data-cart-subtotal-cents="{{ cart.total_price }}" style="display:flex; flex-direction:column; height:100%;">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:var(--space-6); border-bottom:1px solid var(--border-default);">
      <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">{{ 'general.cart.title' | t }} — <span data-cart-count>{{ cart.item_count }}</span></span>
      <button data-cart-close class="as-iconbtn" aria-label="カートを閉じる" style="background:none; border:none; cursor:pointer; color:var(--color-ink); display:flex;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div data-cart-body style="flex:1; overflow-y:auto;">
      {%- if cart.item_count > 0 -%}
        <div data-cart-items>
          {%- for item in cart.items -%}
            <div class="as-cart-item" data-cart-item data-key="{{ item.key }}" data-quantity="{{ item.quantity }}" style="display:grid; grid-template-columns:84px 1fr auto; gap:var(--space-4); padding:var(--space-6); border-bottom:1px solid var(--border-default);">
              <a href="{{ item.url }}" style="aspect-ratio:3/4; background:var(--surface-subtle); overflow:hidden; display:block;">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="200" height="267" style="width:100%; height:100%; object-fit:cover;">{%- endif -%}
              </a>
              <div style="display:flex; flex-direction:column; gap:var(--space-2);">
                <span style="font:var(--text-mono); color:var(--text-tertiary); font-size:10px; text-transform:uppercase;">{{ item.product.type }}</span>
                <h4 style="font-weight:var(--fw-medium); font-size:var(--fs-sm);"><a href="{{ item.url }}">{{ item.product.title }}</a></h4>
                {%- unless item.variant.title contains 'Default' -%}<span style="font:var(--text-mono); color:var(--text-tertiary); font-size:10px;">{{ item.variant.title }}</span>{%- endunless -%}
                <span style="font-size:var(--fs-sm); color:var(--text-secondary);">{{ item.final_price | money }}</span>
                <div style="display:flex; align-items:center; border:1px solid var(--border-default); align-self:flex-start; margin-top:var(--space-2);">
                  <button data-qty-dec aria-label="{{ 'general.cart.decrease' | t }}" style="width:30px; height:30px; background:none; border:none; cursor:pointer; color:var(--color-ink); font-size:var(--fs-md);">−</button>
                  <span data-qty style="width:30px; text-align:center; font:var(--text-body-sm);">{{ item.quantity }}</span>
                  <button data-qty-inc aria-label="{{ 'general.cart.increase' | t }}" style="width:30px; height:30px; background:none; border:none; cursor:pointer; color:var(--color-ink); font-size:var(--fs-md);">+</button>
                </div>
              </div>
              <button data-item-remove class="as-iconbtn" aria-label="{{ 'general.cart.remove' | t }}" style="background:none; border:none; cursor:pointer; color:var(--text-tertiary); align-self:flex-start; display:flex;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div data-cart-empty style="padding:var(--space-24) var(--space-6); text-align:center; display:flex; flex-direction:column; gap:var(--space-4); align-items:center;">
          <span style="font:var(--text-mono); color:var(--text-tertiary); text-transform:uppercase; letter-spacing:var(--tracking-wide); font-size:var(--fs-xs);">{{ 'general.cart.empty' | t }}</span>
          <button data-cart-close class="as-fillbtn" style="border:1px solid var(--color-ink); background:none; cursor:pointer; padding:13px var(--space-8); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink);">{{ 'general.cart.continue_shopping' | t }}</button>
        </div>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div data-cart-footer style="border-top:1px solid var(--border-default); padding:var(--space-6);">
        <div style="margin-bottom:var(--space-4);">
          <span data-freeship-msg style="font:var(--text-mono); font-size:10px; text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-secondary); display:block; margin-bottom:var(--space-2);">
            {%- if remaining > 0 -%}あと {{ remaining | money }} で送料無料{%- else -%}送料無料が適用されます{%- endif -%}
          </span>
          <div style="height:5px; background:var(--surface-subtle);">
            <div data-freeship-bar style="height:100%; background:var(--color-ink); width:{{ pct }}%; transition:width var(--dur-base) var(--ease-standard);"></div>
          </div>
        </div>

        <div style="display:flex; align-items:center; border:1px solid var(--border-default); margin-bottom:var(--space-2);">
          <input data-coupon-input placeholder="{{ 'general.cart.coupon_placeholder' | t }}" class="as-input" style="flex:1; padding:var(--space-3);">
          <button data-coupon-apply style="background:var(--color-ink); color:var(--color-white); border:none; cursor:pointer; padding:0 var(--space-5); align-self:stretch; font:var(--text-label); text-transform:uppercase; font-size:10px; letter-spacing:var(--tracking-wide);">{{ 'general.cart.coupon_apply' | t }}</button>
        </div>
        <span data-coupon-msg hidden data-invalid-text="{{ 'general.cart.coupon_invalid' | t }}" data-applied-template="{{ 'general.cart.coupon_applied' | t: code: '__CODE__', percent: '__PERCENT__' }}" style="font:var(--text-body-sm); color:var(--text-secondary); display:block; margin-bottom:var(--space-3);"></span>

        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--space-2);">
          <span style="font:var(--text-body-sm); color:var(--text-secondary); text-transform:uppercase; letter-spacing:var(--tracking-wide);">{{ 'general.cart.subtotal' | t }}</span>
          <span data-cart-subtotal style="font-weight:var(--fw-semibold); font-size:var(--fs-md);">{{ cart.total_price | money }}</span>
        </div>
        <div data-cart-discount-row hidden style="display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--space-2);">
          <span style="font:var(--text-body-sm); color:var(--text-secondary); text-transform:uppercase; letter-spacing:var(--tracking-wide);">{{ 'general.cart.discount' | t }}</span>
          <span data-cart-discount style="font-weight:var(--fw-semibold); font-size:var(--fs-md);"></span>
        </div>
        <p style="font:var(--text-mono); color:var(--text-tertiary); font-size:10px; margin-bottom:var(--space-4);">{{ 'general.cart.shipping_note' | t }}</p>

        <a href="{{ routes.cart_url }}" style="display:block; text-align:center; width:100%; background:none; color:var(--color-ink); border:1px solid var(--color-ink); cursor:pointer; padding:13px; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); margin-bottom:var(--space-3);">{{ 'general.cart.view' | t }}</a>
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" name="checkout" style="width:100%; background:var(--color-ink); color:var(--color-white); border:1px solid var(--color-ink); cursor:pointer; padding:16px; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">{{ 'general.cart.checkout' | t }}</button>
        </form>
      </div>
    {%- endif -%}
  </div>
</aside>

<style>
  .as-cart-drawer.is-open { transform: translateX(0) !important; }
  .as-cart-scrim.is-open { opacity: 1 !important; }
  body.as-drawer-open { overflow: hidden; }
</style>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
