{%- comment -%}
  "From the Journal" 3-up article grid, backed by a blog picker. Falls back
  to the "journal" blog handle when no blog is assigned in section settings,
  so the home page shows real articles as soon as that blog exists. Renders
  demo cards only when neither is available.
{%- endcomment -%}
{%- liquid
  assign journal_blog = section.settings.blog | default: blogs.journal
-%}
<section style="border-bottom:1px solid var(--border-default);">
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-12); display:flex; align-items:flex-end; justify-content:space-between; gap:var(--space-6); flex-wrap:wrap;">
    <h2 style="font-weight:var(--fw-bold); font-size:var(--fs-3xl); letter-spacing:var(--tracking-tight); text-transform:uppercase;">{{ section.settings.heading }}</h2>
    <a href="{{ journal_blog.url | default: '#' }}" class="as-navlink" style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">All stories</a>
  </div>
  <div class="as-grid-3" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(3,1fr);">
    {%- if journal_blog != blank and journal_blog.articles.size > 0 -%}
      {%- for article in journal_blog.articles limit: 3 -%}
        <a href="{{ article.url }}" class="as-card as-clickable" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default);">
          <div style="aspect-ratio:4/3; overflow:hidden; background:var(--surface-subtle);">
            {%- if article.image -%}
              <img class="as-img" src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" width="{{ article.image.width }}" height="{{ article.image.height }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
            {%- endif -%}
          </div>
          <div style="padding:var(--space-6); display:flex; flex-direction:column; gap:var(--space-3);">
            <span style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-tertiary); font-size:10px;">{{ article.tags.first | default: 'Journal' }} — {{ article.published_at | date: '%b %d, %Y' }}</span>
            <h3 style="font-weight:var(--fw-semibold); font-size:var(--fs-lg); line-height:var(--lh-snug);">{{ article.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..3) -%}
        {%- case i -%}
          {%- when 1 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1509909756405-be0199881695?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Craft' -%}
            {%- assign demo_date = 'Jul 02, 2026' -%}
            {%- assign demo_title = 'Inside the workshop: how a field jacket is made' -%}
          {%- when 2 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Care' -%}
            {%- assign demo_date = 'Jun 18, 2026' -%}
            {%- assign demo_title = 'A guide to repairing raw denim' -%}
          {%- when 3 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1544441893-675973e31985?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Studio' -%}
            {%- assign demo_date = 'Jun 04, 2026' -%}
            {%- assign demo_title = 'Notes from our first Tokyo pop-up' -%}
        {%- endcase -%}
        <div class="as-card" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default);">
          <div style="aspect-ratio:4/3; overflow:hidden; background:var(--surface-subtle);">
            <img class="as-img" src="{{ demo_image }}" alt="{{ demo_title }}" width="800" height="600" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
          </div>
          <div style="padding:var(--space-6); display:flex; flex-direction:column; gap:var(--space-3);">
            <span style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-tertiary); font-size:10px;">{{ demo_cat }} — {{ demo_date }}</span>
            <h3 style="font-weight:var(--fw-semibold); font-size:var(--fs-lg); line-height:var(--lh-snug);">{{ demo_title }}</h3>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Journal",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the Journal" },
    { "type": "blog", "id": "blog", "label": "Blog", "info": "Defaults to the \"journal\" blog handle when left blank." }
  ],
  "presets": [
    { "name": "Journal", "settings": { "heading": "From the Journal" } }
  ]
}
{% endschema %}
