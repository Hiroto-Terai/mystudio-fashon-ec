{%- comment -%}
  Home page hero: split image + copy panel with a CTA into the main collection.
{%- endcomment -%}
<section class="as-hero" style="max-width:var(--page-max); margin:0 auto; display:grid; grid-template-columns:1.05fr 0.95fr; border-bottom:1px solid var(--border-default);">
  <div class="as-card" style="position:relative; overflow:hidden; aspect-ratio:4/5; border-right:1px solid var(--border-default);">
    {%- if section.settings.image -%}
      <img class="as-img" src="{{ section.settings.image | image_url: width: 1600 }}" alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="eager" style="width:100%; height:100%; object-fit:cover;">
    {%- else -%}
      <img class="as-img" src="{{ section.settings.fallback_image }}" alt="" width="1600" height="2000" loading="eager" style="width:100%; height:100%; object-fit:cover;">
    {%- endif -%}
  </div>
  <div style="display:flex; flex-direction:column; justify-content:space-between; padding:var(--space-16) var(--space-12); background:var(--surface-subtle);">
    {%- if section.settings.eyebrow != blank -%}
      <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <div style="display:flex; flex-direction:column; gap:var(--space-8);">
      <h1 style="font-weight:var(--fw-black); font-size:var(--fs-5xl); line-height:var(--lh-tight); letter-spacing:var(--tracking-tight); text-transform:uppercase;">{{ section.settings.heading | newline_to_br }}</h1>
      {%- if section.settings.body != blank -%}
        <p style="max-width:380px; font:var(--text-body); color:var(--text-secondary); line-height:var(--lh-relaxed);">{{ section.settings.body }}</p>
      {%- endif -%}
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="as-fillbtn" style="align-self:flex-start; display:inline-flex; align-items:center; gap:var(--space-3); border:1px solid var(--color-ink); padding:15px var(--space-8); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink);">
        {{ section.settings.button_label }}
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "info": "Used until a real image is picked above.", "default": "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1600&auto=format&fit=crop" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "01 / Seasonal" },
    { "type": "textarea", "id": "heading", "label": "Heading", "info": "One line per break.", "default": "Raw\nStructure\nNo. 01" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "上質なオーガニックコットン、テクニカルなアウター、控えめな金具。削ぎ落とされた一着を、ずっと着るために。" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "コレクションを見る" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "eyebrow": "01 / Seasonal",
        "heading": "Raw\nStructure\nNo. 01",
        "body": "上質なオーガニックコットン、テクニカルなアウター、控えめな金具。削ぎ落とされた一着を、ずっと着るために。",
        "button_label": "コレクションを見る"
      }
    }
  ]
}
{% endschema %}
