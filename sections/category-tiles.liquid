{%- comment -%}
  "Shop by category" grid: a heading row followed by a 4-up hairline grid of
  clickable image tiles with a gradient label overlay. Each tile is a block.
{%- endcomment -%}
<section style="border-bottom:1px solid var(--border-default);">
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-10);">
    {%- if section.settings.eyebrow != blank -%}
      <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2 style="font-weight:var(--fw-bold); font-size:var(--fs-3xl); letter-spacing:var(--tracking-tight); text-transform:uppercase; margin-top:var(--space-4);">{{ section.settings.heading }}</h2>
  </div>
  <div class="as-grid-4" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(4,1fr);">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="as-card as-clickable" style="border-right:1px solid var(--border-default); position:relative; display:block; aspect-ratio:1/1; overflow:hidden;" {{ block.shopify_attributes }}>
        {%- if block.settings.image -%}
          <img class="as-img" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.label | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
        {%- else -%}
          <img class="as-img" src="{{ block.settings.fallback_image }}" alt="{{ block.settings.label | escape }}" width="800" height="800" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
        {%- endif -%}
        <div style="position:absolute; inset:0; display:flex; align-items:flex-end; padding:var(--space-6); background:linear-gradient(to top, rgba(0,0,0,.42), transparent 58%);">
          <span style="color:var(--color-white); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-sm);">{{ block.settings.label }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category tiles",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your archive" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "info": "Used until a real image is picked above.", "default": "https://images.unsplash.com/photo-1551028719-00167b16eac5?q=80&w=800&auto=format&fit=crop" },
        { "type": "text", "id": "label", "label": "Label", "default": "Outerwear" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category tiles",
      "blocks": [
        { "type": "category", "settings": { "label": "Outerwear", "fallback_image": "https://images.unsplash.com/photo-1551028719-00167b16eac5?q=80&w=800&auto=format&fit=crop" } },
        { "type": "category", "settings": { "label": "Denim", "fallback_image": "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=800&auto=format&fit=crop" } },
        { "type": "category", "settings": { "label": "Knitwear", "fallback_image": "https://images.unsplash.com/photo-1489987707025-afc232f7ea0f?q=80&w=800&auto=format&fit=crop" } },
        { "type": "category", "settings": { "label": "Accessories", "fallback_image": "https://images.unsplash.com/photo-1516826957135-700dedea698c?q=80&w=800&auto=format&fit=crop" } }
      ]
    }
  ]
}
{% endschema %}
