{%- comment -%}
  Cart page. Mirrors design-reference Archives-Storefront.html
  <!-- CART PAGE --> view. [data-main-cart-contents] wraps everything that
  changes when a line item is updated so archives.js can swap it in from the
  /cart/change.js Section Rendering response (id: main-cart) without a full
  page reload.
{%- endcomment -%}
<div style="border-bottom:1px solid var(--border-default); min-height:50vh;">
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter);">
    <h1 style="font-weight:var(--fw-black); font-size:var(--fs-4xl); letter-spacing:var(--tracking-tight); text-transform:uppercase; margin-bottom:var(--space-10);">{{ 'general.cart.title' | t }}</h1>

    <div data-main-cart-contents data-cart-subtotal-cents="{{ cart.total_price }}">
      {%- if cart.item_count > 0 -%}
        <div class="as-2col" style="display:grid; grid-template-columns:1.6fr 0.8fr; gap:var(--space-16); align-items:start;">
          <div style="border-top:1px solid var(--border-default);">
            {%- for item in cart.items -%}
              <div class="as-cart-item" data-cart-item data-key="{{ item.key }}" data-quantity="{{ item.quantity }}" style="display:grid; grid-template-columns:100px 1fr auto; gap:var(--space-6); padding:var(--space-6) 0; border-bottom:1px solid var(--border-default); align-items:start;">
                <a href="{{ item.url }}" style="aspect-ratio:3/4; background:var(--surface-subtle); overflow:hidden; display:block;">
                  {%- if item.image -%}<img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" width="240" height="320" style="width:100%; height:100%; object-fit:cover;">{%- endif -%}
                </a>
                <div style="display:flex; flex-direction:column; gap:var(--space-2);">
                  <span style="font:var(--text-mono); color:var(--text-tertiary); font-size:10px; text-transform:uppercase;">{{ item.product.type }}</span>
                  <h4 style="font-weight:var(--fw-medium); font-size:var(--fs-base);"><a href="{{ item.url }}">{{ item.product.title }}</a></h4>
                  {%- unless item.variant.title contains 'Default' -%}<span style="font:var(--text-mono); color:var(--text-tertiary); font-size:10px;">{{ item.variant.title }}</span>{%- endunless -%}
                  <span style="font-size:var(--fs-sm); color:var(--text-secondary);">{{ item.final_price | money }}</span>
                  <div style="display:flex; align-items:center; border:1px solid var(--border-default); align-self:flex-start; margin-top:var(--space-3);">
                    <button data-qty-dec aria-label="{{ 'general.cart.decrease' | t }}" style="width:34px; height:34px; background:none; border:none; cursor:pointer; font-size:var(--fs-md);">−</button>
                    <span data-qty style="width:34px; text-align:center;">{{ item.quantity }}</span>
                    <button data-qty-inc aria-label="{{ 'general.cart.increase' | t }}" style="width:34px; height:34px; background:none; border:none; cursor:pointer; font-size:var(--fs-md);">+</button>
                  </div>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end; gap:var(--space-4);">
                  <span style="font-weight:var(--fw-medium);">{{ item.final_line_price | money }}</span>
                  <button data-item-remove class="as-navlink" style="background:none; border:none; cursor:pointer; font:var(--text-mono); color:var(--text-tertiary); font-size:10px; text-transform:uppercase;">{{ 'general.cart.remove' | t }}</button>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <div style="border:1px solid var(--border-default); padding:var(--space-8); display:flex; flex-direction:column; gap:var(--space-4);">
            <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">{{ 'general.cart.summary' | t }}</span>
            <div style="display:flex; justify-content:space-between; font:var(--text-body-sm); color:var(--text-secondary);">
              <span>{{ 'general.cart.subtotal' | t }}</span>
              <span data-cart-subtotal>{{ cart.total_price | money }}</span>
            </div>
            <div data-cart-discount-row hidden style="display:flex; justify-content:space-between; font:var(--text-body-sm); color:var(--text-secondary);">
              <span>{{ 'general.cart.discount' | t }}</span>
              <span data-cart-discount></span>
            </div>
            <div style="display:flex; justify-content:space-between; font:var(--text-body-sm); color:var(--text-secondary);">
              <span>{{ 'general.cart.shipping' | t }}</span>
              <span>{{ 'general.cart.shipping_value' | t }}</span>
            </div>
            <div style="height:1px; background:var(--border-default);"></div>
            <div style="display:flex; justify-content:space-between; font-weight:var(--fw-semibold); font-size:var(--fs-md);">
              <span>{{ 'general.cart.total' | t }}</span>
              <span data-cart-total>{{ cart.total_price | money }}</span>
            </div>
            <form action="{{ routes.cart_url }}" method="post">
              <button type="submit" name="checkout" style="width:100%; background:var(--color-ink); color:var(--color-white); border:1px solid var(--color-ink); cursor:pointer; padding:16px; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); margin-top:var(--space-2);">{{ 'general.cart.checkout' | t }}</button>
            </form>
          </div>
        </div>
      {%- else -%}
        <div style="padding:var(--space-24) 0; display:flex; flex-direction:column; gap:var(--space-6); align-items:flex-start;">
          <span style="font:var(--text-mono); color:var(--text-tertiary); text-transform:uppercase; letter-spacing:var(--tracking-wide); font-size:var(--fs-sm);">{{ 'general.cart.empty' | t }}.</span>
          <a href="{{ routes.all_products_collection_url }}" class="as-fillbtn" style="border:1px solid var(--color-ink); padding:14px var(--space-8); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink); display:inline-block;">{{ 'general.cart.browse_collection' | t }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main cart",
  "settings": [],
  "presets": [
    { "name": "Main cart" }
  ],
  "enabled_on": {
    "templates": ["cart"]
  }
}
{% endschema %}
