{%- liquid
  assign custom = section.settings.text
  assign threshold = settings.free_shipping_threshold | default: 300
  assign threshold_money = threshold | times: 100 | money_without_trailing_zeros
  if custom != blank
    assign text = custom
  else
    assign text = 'general.shipping.free_shipping_announcement' | t: amount: threshold_money
  endif
-%}
{%- if text != blank -%}
  <div class="as-announcement" style="border-bottom:1px solid var(--border-default); text-align:center; padding:11px var(--space-4);">
    <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-widest); color:var(--text-secondary); font-size:var(--fs-2xs);">{{ text }}</span>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "info": "Leave blank to auto-generate a free-shipping message from the threshold (keeps the store currency in sync)."
    }
  ]
}
{% endschema %}
