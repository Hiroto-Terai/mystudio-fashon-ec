{%- comment -%}
  Editorial split for the 特集 LP: one image beside a copy block (eyebrow /
  heading / body / button). Image side is switchable so stacked rows alternate.
  Scroll-reveals via .as-reveal. Stacks to one column on mobile (.as-hero rule).
{%- endcomment -%}
{%- liquid
  assign image_first = true
  if section.settings.image_side == 'right'
    assign image_first = false
  endif
-%}
<section class="as-hero" style="max-width:var(--page-max); margin:0 auto; display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid var(--border-default);">
  {%- capture media -%}
    <div class="as-card" style="position:relative; overflow:hidden; aspect-ratio:4/5; background:var(--surface-subtle); {% if image_first %}border-right:1px solid var(--border-default);{% else %}border-left:1px solid var(--border-default);{% endif %}">
      {%- if section.settings.image -%}
        <img class="as-img as-reveal" src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
      {%- elsif section.settings.fallback_image != blank -%}
        <img class="as-img as-reveal" src="{{ section.settings.fallback_image }}" alt="" width="1400" height="1750" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
      {%- endif -%}
    </div>
  {%- endcapture -%}
  {%- capture copy -%}
    <div style="display:flex; flex-direction:column; justify-content:center; gap:var(--space-6); padding:var(--space-16) var(--space-12); background:var(--surface-page);">
      {%- if section.settings.eyebrow != blank -%}
        <span class="as-eyebrow as-reveal" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="as-reveal" style="font-weight:var(--fw-bold); font-size:var(--fs-3xl); line-height:var(--lh-tight); letter-spacing:var(--tracking-tight); text-transform:uppercase;">{{ section.settings.heading | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="as-reveal" style="max-width:440px; font:var(--text-body); color:var(--text-secondary); line-height:var(--lh-relaxed);">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="as-reveal" style="align-self:flex-start; display:inline-flex; align-items:center; gap:var(--space-3); border:1px solid var(--color-ink); padding:14px var(--space-8); font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs); color:var(--color-ink);">
          {{ section.settings.button_label }}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {%- endif -%}
    </div>
  {%- endcapture -%}
  {%- if image_first -%}
    {{ media }}{{ copy }}
  {%- else -%}
    {{ copy }}{{ media }}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "LP editorial",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "default": "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=1400&auto=format&fit=crop" },
    { "type": "select", "id": "image_side", "label": "Image side", "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Story" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "素材から、佇まいまで" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "オーガニックコットンとテクニカルなアウター。一着に込めた意図を、写真と言葉で解きほぐします。" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "アイテムを見る" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [ { "name": "LP editorial" } ]
}
{% endschema %}
