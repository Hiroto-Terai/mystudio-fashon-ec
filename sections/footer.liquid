<footer class="as-footer" style="background:var(--surface-page); border-top:1px solid var(--border-default);">
  <div class="as-footer-grid" style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter); display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:var(--space-12);">

    <div style="display:flex; flex-direction:column; gap:var(--space-6);">
      <a href="{{ routes.root_url }}" class="as-clickable" style="font-weight:var(--fw-black); font-size:var(--fs-md); letter-spacing:var(--tracking-widest); text-transform:uppercase; color:var(--color-ink);">{{ section.settings.logo_text | default: 'A R C H I V E S' }}</a>
      {%- if section.settings.blurb != blank -%}
        <p style="font:var(--text-body-sm); color:var(--text-secondary); max-width:300px; line-height:var(--lh-relaxed);">{{ section.settings.blurb }}</p>
      {%- endif -%}
      {%- if section.settings.show_newsletter -%}
        <div style="margin-top:var(--space-4);">
          <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-2xs);">{{ section.settings.newsletter_title | default: 'ニュースレター' }}</span>
          {%- form 'customer', style: 'display:flex; align-items:center; border-bottom:1px solid var(--color-ink); margin-top:var(--space-3); max-width:320px;' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" required placeholder="メールアドレス" style="flex:1; border:none; outline:none; background:none; padding:var(--space-3) 0; font:var(--text-body-sm); letter-spacing:var(--tracking-wide); text-transform:uppercase;">
            <button type="submit" class="as-arrowbtn as-iconbtn" aria-label="登録する" style="background:none; border:none; cursor:pointer; padding:var(--space-2); color:var(--color-ink); display:flex;">
              <svg class="as-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      <div style="display:flex; flex-direction:column; gap:var(--space-4);" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-tertiary); font-size:var(--fs-2xs); margin-bottom:var(--space-2);">{{ block.settings.heading }}</span>
        {%- endif -%}
        {%- for i in (1..6) -%}
          {%- liquid
            assign label_key = 'label_' | append: i
            assign url_key = 'url_' | append: i
            assign link_label = block.settings[label_key]
            assign link_url = block.settings[url_key]
          -%}
          {%- if link_label != blank -%}
            <a href="{{ link_url }}" class="as-navlink as-clickable" style="font:var(--text-body-sm); color:var(--text-secondary); align-self:flex-start;">{{ link_label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>

  <div style="border-top:1px solid var(--border-default);">
    <div style="max-width:var(--page-max); margin:0 auto; padding:var(--space-6) var(--page-gutter); display:flex; align-items:center; justify-content:space-between;">
      <span style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">{{ section.settings.copyright | default: '© 2026 ARCHIVES STUDIO. ALL RIGHTS RESERVED.' }}</span>
      <div style="display:flex; gap:var(--space-6);">
        <a href="{{ routes.root_url }}policies/privacy-policy" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">プライバシー</a>
        <a href="{{ routes.root_url }}policies/terms-of-service" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">利用規約</a>
        <a href="{{ routes.root_url }}pages/tokusho" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">特定商取引法</a>
        <a href="{{ routes.root_url }}pages/analytics-guide" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">計測設定ガイド</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "A R C H I V E S" },
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "長く着られる服とモノを。東京から、世界へ。" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter", "default": true },
    { "type": "text", "id": "newsletter_title", "label": "Newsletter title", "default": "ニュースレター" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 ARCHIVES STUDIO. ALL RIGHTS RESERVED." }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Column heading" },
        { "type": "text", "id": "label_1", "label": "Link 1 label" },
        { "type": "url", "id": "url_1", "label": "Link 1 URL" },
        { "type": "text", "id": "label_2", "label": "Link 2 label" },
        { "type": "url", "id": "url_2", "label": "Link 2 URL" },
        { "type": "text", "id": "label_3", "label": "Link 3 label" },
        { "type": "url", "id": "url_3", "label": "Link 3 URL" },
        { "type": "text", "id": "label_4", "label": "Link 4 label" },
        { "type": "url", "id": "url_4", "label": "Link 4 URL" },
        { "type": "text", "id": "label_5", "label": "Link 5 label" },
        { "type": "url", "id": "url_5", "label": "Link 5 URL" },
        { "type": "text", "id": "label_6", "label": "Link 6 label" },
        { "type": "url", "id": "url_6", "label": "Link 6 URL" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "ショップ", "label_1": "すべての商品", "url_1": "/collections/all", "label_2": "Apparel", "url_2": "/collections/apparel", "label_3": "Outerwear", "url_3": "/collections/outerwear", "label_4": "Hardware", "url_4": "/collections/hardware" } },
        { "type": "menu_column", "settings": { "heading": "スタジオ", "label_1": "ブランドについて", "url_1": "/pages/about", "label_2": "スタイリング", "url_2": "/pages/styling", "label_3": "ジャーナル", "url_3": "/blogs/journal", "label_4": "FAQ", "url_4": "/pages/faq" } },
        { "type": "menu_column", "settings": { "heading": "サポート", "label_1": "検索", "url_1": "/search", "label_2": "ウィッシュリスト", "url_2": "/pages/wishlist", "label_3": "お問い合わせ", "url_3": "/pages/contact", "label_4": "配送・返品", "url_4": "/pages/shipping-returns" } }
      ]
    }
  ]
}
{% endschema %}
