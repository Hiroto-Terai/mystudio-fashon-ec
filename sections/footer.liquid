<footer class="as-footer" style="background:var(--surface-page); border-top:1px solid var(--border-default);">
  <div class="as-footer-grid" style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter); display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:var(--space-12);">

    <div style="display:flex; flex-direction:column; gap:var(--space-6);">
      <a href="{{ routes.root_url }}" class="as-clickable" style="font-weight:var(--fw-black); font-size:var(--fs-md); letter-spacing:var(--tracking-widest); text-transform:uppercase; color:var(--color-ink);">{{ section.settings.logo_text | default: 'A R C H I V E S' }}</a>
      {%- if section.settings.blurb != blank -%}
        <p style="font:var(--text-body-sm); color:var(--text-secondary); max-width:300px; line-height:var(--lh-relaxed);">{{ section.settings.blurb }}</p>
      {%- endif -%}
      {%- if section.settings.show_newsletter -%}
        <div style="margin-top:var(--space-4);">
          <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-2xs);">{{ section.settings.newsletter_title | default: 'Newsletter' }}</span>
          {%- form 'customer', style: 'display:flex; align-items:center; border-bottom:1px solid var(--color-ink); margin-top:var(--space-3); max-width:320px;' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" required placeholder="EMAIL ADDRESS" style="flex:1; border:none; outline:none; background:none; padding:var(--space-3) 0; font:var(--text-body-sm); letter-spacing:var(--tracking-wide); text-transform:uppercase;">
            <button type="submit" class="as-arrowbtn as-iconbtn" aria-label="Subscribe" style="background:none; border:none; cursor:pointer; padding:var(--space-2); color:var(--color-ink); display:flex;">
              <svg class="as-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- assign col_menu = linklists[block.settings.menu] -%}
      <div style="display:flex; flex-direction:column; gap:var(--space-4);" {{ block.shopify_attributes }}>
        <span style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-tertiary); font-size:var(--fs-2xs); margin-bottom:var(--space-2);">{{ block.settings.title | default: col_menu.title }}</span>
        {%- for l in col_menu.links -%}
          <a href="{{ l.url }}" class="as-navlink as-clickable" style="font:var(--text-body-sm); color:var(--text-secondary); align-self:flex-start;">{{ l.title }}</a>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>

  <div style="border-top:1px solid var(--border-default);">
    <div style="max-width:var(--page-max); margin:0 auto; padding:var(--space-6) var(--page-gutter); display:flex; align-items:center; justify-content:space-between;">
      <span style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">{{ section.settings.copyright | default: '© 2026 ARCHIVES STUDIO. ALL RIGHTS RESERVED.' }}</span>
      <div style="display:flex; gap:var(--space-6);">
        <a href="{{ routes.root_url }}policies/privacy-policy" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">PRIVACY</a>
        <a href="{{ routes.root_url }}policies/terms-of-service" class="as-clickable" style="font:var(--text-mono); color:var(--text-tertiary); font-size:var(--fs-2xs);">TERMS</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "A R C H I V E S" },
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "Considered garments and objects, archived for the long term. Tokyo — Worldwide." },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter", "default": true },
    { "type": "text", "id": "newsletter_title", "label": "Newsletter title", "default": "Newsletter" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 ARCHIVES STUDIO. ALL RIGHTS RESERVED." }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "title": "Shop" } },
        { "type": "menu_column", "settings": { "title": "Studio" } },
        { "type": "menu_column", "settings": { "title": "Support" } }
      ]
    }
  ]
}
{% endschema %}
