{%- comment -%}
  Blog / journal index (templates/blog.json): eyebrow + blog title header,
  then a hairline 3-up grid of every article in the blog (image 4/3,
  category — date, title, excerpt), paginated 12 per page. Mirrors the
  EDITORIAL view in design-reference/Archives-Storefront.html and reuses the
  card markup from sections/journal.liquid via snippets/article-card.
{%- endcomment -%}
<div>
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-12);">
    <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
    <h1 style="font-weight:var(--fw-black); font-size:var(--fs-4xl); letter-spacing:var(--tracking-tight); text-transform:uppercase; margin-top:var(--space-4);">{{ blog.title | default: section.settings.fallback_title }}</h1>
  </div>

  {%- paginate blog.articles by 12 -%}
    {%- if blog.articles.size > 0 -%}
      <div class="as-grid-3" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(3,1fr);">
        {%- for article in blog.articles -%}
          {%- render 'article-card', article: article -%}
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="as-pagination" role="navigation" aria-label="{{ 'collection.pagination.label' | t }}" style="max-width:var(--page-max); margin:0 auto; padding:var(--space-10) var(--page-gutter); display:flex; justify-content:center;">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- else -%}
      <div style="max-width:var(--page-max); margin:0 auto; padding:var(--space-16) var(--page-gutter); display:flex; flex-direction:column; align-items:center; gap:var(--space-4); text-align:center; border-top:1px solid var(--border-default);">
        <p style="font:var(--text-body); color:var(--text-secondary);">{{ 'blog.empty' | t }}</p>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Main blog",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ジャーナル" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "ジャーナル" }
  ],
  "presets": [
    { "name": "Main blog" }
  ],
  "enabled_on": {
    "templates": ["blog"]
  }
}
{% endschema %}
