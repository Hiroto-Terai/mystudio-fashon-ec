{%- comment -%}
  "Featured" product grid backed by a collection picker. Renders real products
  via snippets/product-card when a collection is assigned; otherwise renders
  onboarding demo cards so the section still looks complete out of the box.
{%- endcomment -%}
<section style="border-bottom:1px solid var(--border-default);">
  <div style="max-width:var(--page-max); margin:0 auto; padding:var(--section-y) var(--page-gutter) var(--space-12); display:flex; align-items:flex-end; justify-content:space-between; gap:var(--space-6); flex-wrap:wrap;">
    <div style="display:flex; flex-direction:column; gap:var(--space-4);">
      {%- if section.settings.eyebrow != blank -%}
        <span class="as-eyebrow" style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wider); color:var(--text-secondary); font-size:var(--fs-xs);">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 style="font-weight:var(--fw-bold); font-size:var(--fs-3xl); letter-spacing:var(--tracking-tight); text-transform:uppercase;">{{ section.settings.heading }}</h2>
    </div>
    <a href="{{ section.settings.view_all_link | default: section.settings.collection.url | default: routes.all_products_collection_url }}" class="as-navlink" style="font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">すべて見る</a>
  </div>
  <div class="as-grid-4" style="max-width:var(--page-max); margin:0 auto; border-top:1px solid var(--border-default); border-left:1px solid var(--border-default); display:grid; grid-template-columns:repeat(4,1fr);">
    {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      {%- for product in section.settings.collection.products limit: 8 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        {%- case i -%}
          {%- when 1 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1445205170230-053b83016050?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Outerwear' -%}
            {%- assign demo_name = 'Overdyed Field Jacket' -%}
            {%- assign demo_price = '¥68,000' -%}
          {%- when 2 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Bottoms' -%}
            {%- assign demo_name = 'Raw Denim Trouser' -%}
            {%- assign demo_price = '¥42,000' -%}
          {%- when 3 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Tops' -%}
            {%- assign demo_name = 'Heavy Cotton Tee' -%}
            {%- assign demo_price = '¥14,000' -%}
          {%- when 4 -%}
            {%- assign demo_image = 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=800&auto=format&fit=crop' -%}
            {%- assign demo_cat = 'Outerwear' -%}
            {%- assign demo_name = 'Wool Melton Coat' -%}
            {%- assign demo_price = '¥98,000' -%}
        {%- endcase -%}
        <div class="as-card" style="border-right:1px solid var(--border-default); border-bottom:1px solid var(--border-default);">
          <div style="position:relative; overflow:hidden; aspect-ratio:3/4; background:var(--surface-subtle);">
            <img class="as-img" src="{{ demo_image }}" alt="{{ demo_name }}" width="800" height="1067" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
            <button type="button" data-wishlist-toggle="demo-featured-{{ i }}" data-wishlist-ns="products" class="as-wish as-iconbtn" aria-label="ウィッシュリストに追加" style="position:absolute; top:var(--space-3); right:var(--space-3); background:var(--color-white); border:1px solid var(--border-default); width:32px; height:32px; border-radius:999px; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--color-ink);">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8z"></path></svg>
            </button>
            <div class="as-quickadd">
              <button type="button" disabled title="コレクションを設定するとクイック追加が有効になります" style="width:100%; background:var(--color-n-300); color:var(--color-white); border:none; cursor:not-allowed; padding:15px; font:var(--text-label); text-transform:uppercase; letter-spacing:var(--tracking-wider); font-size:var(--fs-xs);">{{ 'products.product.quick_add' | t }}</button>
            </div>
          </div>
          <div style="padding:var(--space-5); display:flex; flex-direction:column; gap:var(--space-2);">
            <span style="font:var(--text-mono); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-tertiary); font-size:10px;">{{ demo_cat }}</span>
            <h3 style="font-weight:var(--fw-medium); font-size:var(--fs-base);">{{ demo_name }}</h3>
            <span style="font-size:var(--fs-sm); color:var(--text-secondary);">{{ demo_price }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured / FW26" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "コア セレクション" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "view_all_link", "label": "\"View all\" link" }
  ],
  "presets": [
    { "name": "Featured collection", "settings": { "eyebrow": "Featured / FW26", "heading": "コア セレクション" } }
  ]
}
{% endschema %}
